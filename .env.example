# PostgreSQL bağlantı URL'i. asyncpg kullanıldığı için backend tarafında postgresql+asyncpg://... yazılır.
# Örnek: postgresql+asyncpg://postgres:postgres@db:5432/postgres
DATABASE_URL=

# JWT ve oturum imzası için en az 32 karakter rastgele string. Production'da mutlaka güçlü ve gizli tutulmalı.
SECRET_KEY=

# Twilio SMS hesabı (MVP'de OTP için kullanılacak)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Ana domain; örn: app.com. Subdomain'ler buraya göre çözümlenir.
APP_DOMAIN=

# İzin verilen subdomain'ler; virgülle ayrılmış liste. Örn: berber1,berber2
ALLOWED_SUBDOMAINS=

# Ortam: development veya production
ENV=development
